        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस गोपनीयता नीति के बारे में प्रश्नों या चिंताओं के लिए, डेवलपर से bonjour@withframes.com पर संपर्क करें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Za pitanja ili primjedbe vezane uz ova Pravila o privatnosti obratite se razvojnom programeru na adresu bonjour@withframes.com."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az Adatvédelmi szabályzattal kapcsolatos kérdésekkel vagy észrevételekkel forduljon a fejlesztőhöz a bonjour@withframes.com címen."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Untuk pertanyaan atau kekhawatiran mengenai Kebijakan Privasi ini, hubungi pengembang di bonjour@withframes.com."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Per domande o dubbi riguardanti la presente Informativa sulla privacy, contattare lo sviluppatore all'indirizzo bonjour@withframes.com."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本プライバシーポリシーに関するご質問やご不明な点がございましたら、bonjour@withframes.com まで開発者にお問い合わせください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "본 개인정보 처리방침에 관한 질문이나 우려 사항이 있으시면 bonjour@withframes.com으로 개발자에게 문의하세요."
