        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para dúvidas ou preocupações relacionadas a esta Política de Privacidade, entre em contato com o desenvolvedor em bonjour@withframes.com."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pentru întrebări sau preocupări referitoare la această Politică de confidențialitate, contactați dezvoltatorul la bonjour@withframes.com."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "По вопросам, связанным с настоящей Политикой конфиденциальности, обращайтесь к разработчику по адресу bonjour@withframes.com."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "V prípade otázok alebo pripomienok k týmto Zásadám ochrany osobných údajov kontaktujte vývojára na adrese bonjour@withframes.com."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "För frågor eller funderingar angående denna integritetspolicy, kontakta utvecklaren på bonjour@withframes.com."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หากมีคำถามหรือข้อกังวลเกี่ยวกับนโยบายความเป็นส่วนตัวนี้ โปรดติดต่อนักพัฒนาที่ bonjour@withframes.com"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu Gizlilik Politikası ile ilgili sorularınız veya endişeleriniz için bonjour@withframes.com adresinden geliştiriciyle iletişime geçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "З питань або занепокоєнь щодо цієї Політики конфіденційності звертайтеся до розробника за адресою bonjour@withframes.com."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đối với các câu hỏi hoặc thắc mắc liên quan đến Chính sách Bảo mật này, vui lòng liên hệ nhà phát triển tại bonjour@withframes.com."
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "如對本私隱政策有任何疑問或顧慮，請透過 bonjour@withframes.com 聯繫開發者。"
          }
