        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Για ερωτήσεις ή ανησυχίες σχετικά με την παρούσα Πολιτική Απορρήτου, επικοινωνήστε με τον προγραμματιστή στο bonjour@withframes.com."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For questions or concerns regarding this Privacy Policy, contact the developer at bonjour@withframes.com."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Para preguntas o inquietudes sobre esta Política de Privacidad, contacte al desarrollador en bonjour@withframes.com."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kysymyksiä tai huolenaiheita tästä tietosuojakäytännöstä voi osoittaa kehittäjälle osoitteessa bonjour@withframes.com."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pour toute question ou préoccupation concernant la présente Politique de confidentialité, veuillez contacter le développeur à l'adresse bonjour@withframes.com."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לשאלות או חששות בנוגע למדיניות פרטיות זו, ניתן לפנות למפתח בכתובת bonjour@withframes.com."
